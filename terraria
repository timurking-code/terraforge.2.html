const nnx=this.cont.x+this.vx,bx=Math.floor(nnx/TS),by=Math.floor((this.cont.y-this.h*.5)/TS),by2=Math.floor(this.cont.y/TS);
if(!this.solid(bx,by)&&!this.solid(bx,by2))this.cont.x=Phaser.Math.Clamp(nnx,0,WW*TS);else{this.vx=0;this.facing*=-1;}
if(this.onG&&this.solid(Math.floor((this.cont.x+this.facing*TS*1.2)/TS),Math.floor(this.cont.y/TS)))this.vy=-6.5;
const nny=this.cont.y+this.vy;this.onG=false;if(!this.solid(Math.floor(this.cont.x/TS),Math.floor(nny/TS)))this.cont.y=nny;else{if(this.vy>0)this.onG=true;this.vy=0;}
this.draw();
}
takeDamage(dmg,vx,vy){
if(!this.alive||this.invCD>0)return;this.hp-=dmg;this.invCD=200;
if(this.hp<=0){
this.alive=false;
this.sc.time.delayedCall(350,()=>{this.gfx.clear();this.dead=true;});
this.sc.time.delayedCall(30,()=>this.sc.breakFX(this.cont.x,this.cont.y,{a:this.color,b:0xcc2222}));
const loot={goblin:[‘coal’,‘iron’,‘meat’],slime:[‘dirt’,‘stone’],zombie:[‘plank’,‘iron’,‘meat’],eye:[‘iron’,‘coal’],knight:[‘iron’,‘ironbar’],demon:[‘coal’,‘iron’]}[this.type]||[‘dirt’];
this.sc.spawnDrop(this.cont.x,this.cont.y,loot[Math.floor(Math.random()*loot.length)]);
}else{this.vx=vx||0;this.vy=vy||-3;}
}
}

/* ══ ANIMAL ══ */
class Animal{
constructor(scene,x,y,type){
this.sc=scene;this.type=type;this.alive=true;this.dead=false;
this.cont=scene.add.container(x,y).setDepth(10);this.gfx=scene.add.graphics();this.cont.add(this.gfx);
this.vx=0;this.vy=0;this.onG=false;this.facing=Math.random()<.5?1:-1;
this.stateT=0;this.idleT=2000+Math.random()*3000;this.moving=false;
this.fleeing=false;this.invCD=0;
if(type===‘rabbit’){this.hp=this.maxHp=15;this.color=0xddccbb;this.w=6;this.h=8;this.drop=‘meat’;}
else{this.hp=this.maxHp=40;this.color=0xaa8855;this.w=10;this.h=14;this.drop=‘meat’;}
this.draw();
}
solid(tx,ty){if(tx<0||tx>=WW||ty<0||ty>=WH)return true;const t=this.sc.map[tx][ty];return t!==0&&t!==9&&t!==5&&t!==11;}
draw(){
const g=this.gfx;g.clear();if(!this.alive)return;
if(this.type===‘rabbit’){
const hop=this.moving?Math.abs(Math.sin(Date.now()*.02))*5:0;
g.fillStyle(0x000000,.12);g.fillEllipse(0,this.h/2+2,this.w*1.5,3);
g.fillStyle(this.color);g.fillEllipse(0,-hop,this.w,this.h);
// Head
g.fillStyle(this.color);g.fillEllipse(this.facing*3,-this.h/2-hop,this.w*.8,this.h*.6);
// Ears
g.fillStyle(this.color);g.fillRect(this.facing*2-1,-this.h-5-hop,2,6);g.fillRect(this.facing*4-1,-this.h-5-hop,2,6);
g.fillStyle(0xffaaaa);g.fillRect(this.facing*2,-this.h-4-hop,1,4);g.fillRect(this.facing*4,-this.h-4-hop,1,4);
// Eye
g.fillStyle(0x220000);g.fillCircle(this.facing*4,-this.h/2-1-hop,1.5);
g.fillStyle(0xff0000,.4);g.fillCircle(this.facing*3,-this.h/2-3-hop,1);
} else {
// Deer
const walk=this.moving?Math.sin(Date.now()*.012)*8:0;
g.fillStyle(0x000000,.15);g.fillEllipse(0,this.h/2+2,this.w*2,4);
// Legs
g.fillStyle(0x886633);g.fillRect(-this.w/2,this.h/4,3,this.h/2+walk*.3);g.fillRect(-this.w/6,this.h/4,3,this.h/2-walk*.3);g.fillRect(this.w/6,this.h/4,3,this.h/2+walk*.2);g.fillRect(this.w/2-2,this.h/4,3,this.h/2-walk*.2);
// Body
g.fillStyle(this.color);g.fillEllipse(0,0,this.w*1.8,this.h*.7);
// Head/neck
g.fillStyle(this.color);g.fillEllipse(this.facing*this.w*.7,-this.h*.4,this.w*.7,this.h*.6);
// Antlers
g.fillStyle(0x664422);g.fillRect(this.facing*this.w*.6,-this.h*.8,1,6);g.fillRect(this.facing*this.w*.6-2,-this.h*.7,4,1);
// Eye
g.fillStyle(0x221100);g.fillCircle(this.facing*this.w*.9,-this.h*.4,2);
g.fillStyle(0xffffff);g.fillCircle(this.facing*this.w*.9+.5,-this.h*.4-.5,0.8);
// Tail
g.fillStyle(0xffffff);g.fillCircle(-this.facing*this.w*.9,0,3);
}
if(this.hp<this.maxHp){const hg=this.gfx;hg.fillStyle(0x660000);hg.fillRect(-10,-this.h-12,20,3);hg.fillStyle(0x44ff44);hg.fillRect(-10,-this.h-12,20*(this.hp/this.maxHp),3);}
}
update(dt){
if(!this.alive)return;if(this.invCD>0)this.invCD-=dt;
this.stateT+=dt;
// Flee from player
const sc=this.sc;const pdx=this.cont.x-sc.pC.x,pdy=this.cont.y-sc.pC.y;
const pdist=Math.sqrt(pdx*pdx+pdy*pdy);
this.fleeing=pdist<100;
let spd=this.fleeing?(this.type===‘rabbit’?3.5:2.5):0.8;
if(this.fleeing){this.facing=pdx>0?1:-1;this.vx=this.facing*spd;}
else if(this.stateT>this.idleT){this.stateT=0;this.idleT=2000+Math.random()*3000;this.moving=!this.moving;if(this.moving)this.facing=Math.random()<.5?1:-1;}
this.vx=this.moving||this.fleeing?this.facing*spd:0;
this.vy=Math.min(this.vy+.35,14);
const nx=this.cont.x+this.vx;const bx=Math.floor(nx/TS),by=Math.floor(this.cont.y/TS),by2=Math.floor((this.cont.y-this.h)/TS);
if(!this.solid(bx,by)&&!this.solid(bx,by2))this.cont.x=Phaser.Math.Clamp(nx,0,WW*TS);else{this.vx=0;this.facing*=-1;}
if(this.onG&&this.solid(Math.floor((this.cont.x+this.facing*TS)/TS),Math.floor(this.cont.y/TS)))this.vy=-5;
const ny=this.cont.y+this.vy;this.onG=false;
if(!this.solid(Math.floor(this.cont.x/TS),Math.floor(ny/TS)))this.cont.y=ny;else{if(this.vy>0)this.onG=true;this.vy=0;}
this.draw();
}
takeDamage(dmg){
if(!this.alive||this.invCD>0)return;this.hp-=dmg;this.invCD=200;
if(this.hp<=0){
this.alive=false;
this.sc.time.delayedCall(300,()=>{this.gfx.clear();this.dead=true;});
this.sc.breakFX(this.cont.x,this.cont.y,{a:this.color,b:0xaa6633});
const drops=this.type===‘deer’?3:1;
for(let i=0;i<drops;i++)this.sc.spawnDrop(this.cont.x+(Math.random()-0.5)*20,this.cont.y,‘meat’);
showToast(`🥩 Got ${drops} meat! (Press F to eat)`);
}else{this.vx=this.facing*-4;this.vy=-3;}
}
}

new Phaser.Game({type:Phaser.AUTO,width:IS_MOBILE?window.innerWidth:800,height:IS_MOBILE?window.innerHeight:500,backgroundColor:’#000008’,parent:document.body,scale:{mode:Phaser.Scale.FIT,autoCenter:Phaser.Scale.CENTER_BOTH},physics:{default:‘arcade’},scene:[MenuScene,GameScene]});
</script>

