feats.forEach((f,i)=>this.add.text(W/2,H*.38+i*18,f,{fontFamily:’“Courier New”,monospace’,fontSize:‘12px’,color:’#88ccaa’}).setOrigin(.5));
const mk=(bx,by,lbl,col,cb)=>{const bg=this.add.graphics();const dr=h=>{bg.clear();bg.fillStyle(h?col+0x222222:col,.92);bg.fillRoundedRect(bx-110,by-22,220,44,8);bg.lineStyle(2,h?0xffffff:col+0x444444);bg.strokeRoundedRect(bx-110,by-22,220,44,8);};dr(false);const tx=this.add.text(bx,by,lbl,{fontFamily:’“Courier New”,monospace’,fontSize:‘22px’,color:’#fff’,stroke:’#111’,strokeThickness:3}).setOrigin(.5).setInteractive({cursor:‘pointer’});tx.on(‘pointerover’,()=>dr(true));tx.on(‘pointerout’,()=>dr(false));tx.on(‘pointerdown’,cb);};
mk(W/2,H*.76,‘▶  New Game’,0x1a4a1a,()=>{this.cameras.main.fadeOut(400,0,0,0);this.time.delayedCall(400,()=>this.scene.start(‘Game’));});
this.add.text(W/2,H-16,IS_MOBILE?‘Joystick:Move · ↑Jump · ⚔Attack · ⛏Mine · ⚒Craft · F:Eat’:‘WASD:Move · Space:Jump · LMB:Mine/Attack · RMB:Place · 1-9:Slots · C:Craft · F:Eat’,{fontFamily:’“Courier New”,monospace’,fontSize:‘10px’,color:’#8899aa’}).setOrigin(.5);
}
}

