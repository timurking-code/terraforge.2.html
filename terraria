<script>
const TS=16,WW=400,WH=200;
const T={AIR:0,GRASS:1,DIRT:2,STONE:3,WOOD:4,LEAVES:5,COAL:6,IRON:7,SAND:8,WATER:9,BEDROCK:10,TORCH:11,PLANK:12};
const TC={1:{a:0x5d8a3c,b:0x3d6a1c},2:{a:0xa07840,b:0x7a5820},3:{a:0x909090,b:0x686868},4:{a:0xa06030,b:0x784820},5:{a:0x3a8a2a,b:0x1a5a0a},6:{a:0x606060,b:0x333333},7:{a:0x909090,b:0xcc8844},8:{a:0xd0c080,b:0xa89840},9:{a:0x2060cc,b:0x1040aa},10:{a:0x303030,b:0x181818},11:{a:0xff9900,b:0xff5500},12:{a:0xb07840,b:0x805820}};
const THP={1:2,2:3,3:8,4:5,5:1,6:10,7:12,8:2,9:9999,10:9999,11:1,12:4};
const TDROP={1:'dirt',2:'dirt',3:'stone',4:'wood',5:null,6:'coal',7:'iron',8:'sand',11:'torch',12:'plank'};
const ITEMS={
  pickaxe:{name:'Pickaxe',color:0xcccccc,isBlock:false,spd:5.5,dmg:8},
  ironpick:{name:'Iron Pick',color:0xddaa55,isBlock:false,spd:9,dmg:15},
  sword:{name:'Sword',color:0x4488ff,isBlock:false,dmg:25},
  ironsword:{name:'Iron Sword',color:0xddaa55,isBlock:false,dmg:50},
  dirt:{name:'Dirt',color:0xa07840,isBlock:true,tile:2},
  stone:{name:'Stone',color:0x909090,isBlock:true,tile:3},
  wood:{name:'Wood',color:0xa06030,isBlock:true,tile:4},
  plank:{name:'Plank',color:0xb07840,isBlock:true,tile:12},
  coal:{name:'Coal',color:0x444444,isBlock:false},
  iron:{name:'Iron',color:0xcc8844,isBlock:false},
  sand:{name:'Sand',color:0xd0c080,isBlock:true,tile:8},
  leaves:{name:'Leaves',color:0x3a8a2a,isBlock:true,tile:5},
  torch:{name:'Torch',color:0xff9900,isBlock:true,tile:11},
  ironbar:{name:'Iron Bar',color:0xddaa77,isBlock:false},
  meat:{name:'Raw Meat',color:0xdd6644,isBlock:false,heal:20},
  cookedmeat:{name:'Cooked Meat',color:0xcc4422,isBlock:false,heal:50},
  bandage:{name:'Bandage',color:0xffaaaa,isBlock:false,heal:35},
};
const RECIPES=[
  {r:'plank',n:4,need:{wood:1},label:'Plank x4',req:'wood x1'},
  {r:'torch',n:4,need:{wood:1,coal:1},label:'Torch x4',req:'wood x1 + coal x1'},
  {r:'ironbar',n:1,need:{iron:3},label:'Iron Bar',req:'iron x3'},
  {r:'ironpick',n:1,need:{ironbar:3,wood:2},label:'Iron Pickaxe',req:'ironbar x3 + wood x2'},
  {r:'ironsword',n:1,need:{ironbar:4,wood:1},label:'Iron Sword',req:'ironbar x4 + wood x1'},
  {r:'bandage',n:2,need:{plank:4},label:'Bandage x2',req:'plank x4'},
  {r:'cookedmeat',n:1,need:{meat:1,coal:1},label:'Cooked Meat',req:'meat x1 + coal x1'},
];
function lerp(a,b,t){return a+(b-a)*t;}
function rgb(r,g,b){return((r&255)<<16)|((g&255)<<8)|(b&255);}
const IS_MOBILE=/iPhone|iPad|iPod|Android/i.test(navigator.userAgent)||('ontouchstart' in window);
function showToast(m,dur=2200){const t=document.getElementById('toast');t.textContent=m;t.style.opacity='1';clearTimeout(t._t);t._t=setTimeout(()=>t.style.opacity='0',dur);}

// CRAFT
let craftOpen=false;
function openCraft(){
craftOpen=true;
const sc=window.GS,list=document.getElementById(‘recipeList’);list.innerHTML=’’;
RECIPES.forEach((r,i)=>{
const can=sc?Object.entries(r.need).every(([k,v])=>{const s=sc.slots.find(s=>s&&s.type===k);return s&&s.count>=v;}):false;
const d=document.createElement(‘div’);d.className=‘cR’;
d.innerHTML=`<div><div class="cRn">${r.label}</div><div class="cRr">${r.req}</div></div><button class="cRb" ${can?'':'disabled style="opacity:.4"'} onclick="doCraft(${i})">Craft</button>`;
list.appendChild(d);
});
document.getElementById(‘craftPanel’).style.display=‘block’;
}
function closeCraft(){
craftOpen=false;
document.getElementById(‘craftPanel’).style.display=‘none’;
}
function doCraft(i){
const sc=window.GS,r=RECIPES[i];if(!sc)return;
const can=Object.entries(r.need).every(([k,v])=>{const s=sc.slots.find(s=>s&&s.type===k);return s&&s.count>=v;});
if(!can){showToast(‘Not enough materials!’);return;}
Object.entries(r.need).forEach(([k,v])=>sc.removeItem(k,v));
sc.addItem(r.r,r.n);sc.refreshHB();showToast(`✅ Crafted: ${r.label}`);openCraft();
}

// MUSIC
let audioCtx=null,musicOn=true,musicInterval=null,musicNodes=[];
const MA=[‘E4’,‘D4’,‘C4’,‘D4’,‘E4’,‘E4’,‘E4’,‘R’,‘D4’,‘D4’,‘D4’,‘R’,‘E4’,‘G4’,‘G4’,‘R’,‘E4’,‘D4’,‘C4’,‘D4’,‘E4’,‘E4’,‘E4’,‘E4’,‘D4’,‘D4’,‘E4’,‘D4’,‘C4’,‘R’,‘R’,‘R’];
const MB=[‘C4’,‘E4’,‘G4’,‘E4’,‘C4’,‘G3’,‘A3’,‘B3’,‘C4’,‘E4’,‘G4’,‘A4’,‘G4’,‘E4’,‘D4’,‘C4’,‘F3’,‘A3’,‘C4’,‘E4’,‘D4’,‘B3’,‘G3’,‘E3’,‘C3’,‘E3’,‘G3’,‘C4’,‘B3’,‘G3’,‘E3’,‘C3’];
const BA=[‘C3’,‘R’,‘G2’,‘R’,‘C3’,‘R’,‘G2’,‘R’,‘F2’,‘R’,‘C3’,‘R’,‘G2’,‘R’,‘D3’,‘R’,‘C3’,‘R’,‘G2’,‘R’,‘C3’,‘R’,‘G2’,‘R’,‘F2’,‘R’,‘G2’,‘R’,‘C2’,‘R’,‘R’,‘R’];
const BB=[‘C2’,‘R’,‘G2’,‘R’,‘F2’,‘R’,‘C3’,‘R’,‘G2’,‘R’,‘D3’,‘R’,‘C3’,‘R’,‘G2’,‘R’,‘F2’,‘R’,‘C3’,‘R’,‘G2’,‘R’,‘D3’,‘R’,‘C2’,‘R’,‘G2’,‘R’,‘C3’,‘R’,‘G2’,‘R’];
function nF(n){if(n===‘R’)return 0;const nm={C:0,D:2,E:4,F:5,G:7,A:9,B:11};const o=parseInt(n.slice(-1)),s=nm[n[0]];return 440*Math.pow(2,(s-9+(o-4)*12)/12);}
function startMusic(){if(!audioCtx)audioCtx=new(window.AudioContext||window.webkitAudioContext)();if(audioCtx.state===‘suspended’)audioCtx.resume();stopMusic();const bs=60/110;let mi=0,bi=0,mt=0,bt=0;const master=audioCtx.createGain();master.gain.value=0.18;master.connect(audioCtx.destination);musicNodes.push(master);const M=[MA,MB],B=[BA,BB];function play(f,d,type,v){if(!f||!musicOn)return;const o=audioCtx.createOscillator(),g=audioCtx.createGain();o.type=type;o.frequency.value=f;g.gain.setValueAtTime(v,audioCtx.currentTime);g.gain.exponentialRampToValueAtTime(0.001,audioCtx.currentTime+d*.88);o.connect(g);g.connect(master);o.start();o.stop(audioCtx.currentTime+d);musicNodes.push(o,g);}function tick(){if(!musicOn)return;play(nF(M[mt][mi]),bs*.85,‘square’,0.15);play(nF(B[bt][bi]),bs*.9,‘sawtooth’,0.1);if(nF(M[mt][mi])&&Math.random()<.25)play(nF(M[mt][mi])*1.5,bs*.6,‘triangle’,0.05);mi=(mi+1)%M[mt].length;bi=(bi+1)%B[bt].length;if(mi===0)mt=(mt+1)%M.length;if(bi===0)bt=(bt+1)%B.length;}tick();musicInterval=setInterval(tick,bs*1000);}
function stopMusic(){if(musicInterval){clearInterval(musicInterval);musicInterval=null;}musicNodes.forEach(n=>{try{n.stop&&n.stop();n.disconnect();}catch(e){}});musicNodes=[];}
function toggleMusic(){musicOn=!musicOn;document.getElementById(‘musicBtn’).textContent=’♪ ’+(musicOn?‘ON’:‘OFF’);if(musicOn)startMusic();else stopMusic();}
let _ms=false;function tryM(){if(!_ms&&musicOn){_ms=true;startMusic();}}
[‘pointerdown’,‘touchstart’,‘keydown’].forEach(e=>document.addEventListener(e,tryM,{once:true}));

// WORLD GEN
function genWorld(){
const map=[];for(let x=0;x<WW;x++)map[x]=new Array(WH).fill(0);
const surf=[];for(let x=0;x<WW;x++)surf[x]=Math.round(75+Math.sin(x*.028)*10+Math.sin(x*.07+1.1)*5+Math.sin(x*.18+2.3)*3+Math.sin(x*.4+.7)*1.5);
for(let x=0;x<WW;x++)for(let y=0;y<WH;y++){if(y>=WH-1){map[x][y]=10;continue;}if(y>surf[x]+25)map[x][y]=3;else if(y>surf[x])map[x][y]=2;else if(y===surf[x])map[x][y]=1;}
for(let i=0;i<42;i++){let cx=(Math.random()*WW)|0,cy=(surf[cx]+15+Math.random()*65)|0,ang=Math.random()*Math.PI*2;for(let j=0,len=40+Math.random()*100;j<len;j++){ang+=(Math.random()-.5)*.9;cx+=Math.cos(ang);cy+=Math.sin(ang)*.6;const r=2+Math.random()*3;for(let dx=-r-1;dx<=r+1;dx++)for(let dy=-r-1;dy<=r+1;dy++){if(dx*dx+dy*dy>r*r)continue;const nx=(cx+dx)|0,ny=(cy+dy)|0;if(nx>1&&nx<WW-2&&ny>5&&ny<WH-2&&map[nx][ny]!==10)map[nx][ny]=0;}}}
for(let i=0;i<380;i++){const x=(1+Math.random()*(WW-2))|0,y=(surf[x]+10+Math.random()*(WH-surf[x]-15))|0;const ore=Math.random()<.6?6:7;for(let dx=-1;dx<=1;dx++)for(let dy=-1;dy<=1;dy++){const nx=x+dx,ny=y+dy;if(nx>0&&nx<WW&&ny>0&&ny<WH&&map[nx][ny]===3&&Math.random()<.7)map[nx][ny]=ore;}}
for(let x=5;x<WW-5;x++){if(Math.random()<.08&&map[x][surf[x]]===1&&Math.abs(surf[x]-surf[x-1])<=2&&Math.abs(surf[x]-surf[x+1])<=2){const h=5+((Math.random()*4)|0);for(let y=surf[x]-h;y<surf[x];y++)if(y>=0)map[x][y]=4;const lr=3+(Math.random()*2|0),lt=surf[x]-h-1;for(let dx=-lr;dx<=lr;dx++)for(let dy=-lr;dy<=lr;dy++){if(dx*dx*.6+dy*dy>lr*lr+1)continue;const lx=x+dx,ly=lt+dy;if(lx>0&&lx<WW&&ly>0&&ly<WH&&map[lx][ly]===0)map[lx][ly]=5;}}}
for(let x=0;x<WW;x++)if(surf[x]>82)for(let y=surf[x];y<Math.min(WH-1,surf[x]+6);y++)if([2,1,3].includes(map[x][y]))map[x][y]=8;
return{map,surf};
}

// MOBILE
const joy={id:null,dx:0,dy:0};const mBtns={jump:false,atk:false,mine:false};
function setupMobile(){
if(!IS_MOBILE)return;
document.getElementById(‘mobileHUD’).classList.add(‘visible’);
const zone=document.getElementById(‘joyZone’),knob=document.getElementById(‘joyKnob’),MR=42;
function mv(id,cx,cy){if(joy.id!==id)return;const r=zone.getBoundingClientRect(),ox=r.left+r.width/2,oy=r.top+r.height/2;let dx=cx-ox,dy=cy-oy;const d=Math.sqrt(dx*dx+dy*dy);if(d>MR){dx=dx/d*MR;dy=dy/d*MR;}joy.dx=dx/MR;joy.dy=dy/MR;knob.style.transform=`translate(calc(-50% + ${dx}px),calc(-50% + ${dy}px))`;}
zone.addEventListener(‘touchstart’,e=>{e.preventDefault();const t=e.changedTouches[0];joy.id=t.identifier;mv(t.identifier,t.clientX,t.clientY);},{passive:false});
zone.addEventListener(‘touchmove’,e=>{e.preventDefault();for(const t of e.changedTouches)mv(t.identifier,t.clientX,t.clientY);},{passive:false});
zone.addEventListener(‘touchend’,e=>{for(const t of e.changedTouches)if(t.identifier===joy.id){joy.id=null;joy.dx=0;joy.dy=0;knob.style.transform=‘translate(-50%,-50%)’;}});
function btn(id,k){const el=document.getElementById(id);el.addEventListener(‘touchstart’,e=>{e.preventDefault();mBtns[k]=true;el.classList.add(‘pressed’);},{passive:false});el.addEventListener(‘touchend’,()=>{mBtns[k]=false;el.classList.remove(‘pressed’);});el.addEventListener(‘touchcancel’,()=>{mBtns[k]=false;el.classList.remove(‘pressed’);});}
btn(‘btnJump’,‘jump’);btn(‘btnAtk’,‘atk’);btn(‘btnMine’,‘mine’);
document.getElementById(‘btnCraft’).addEventListener(‘touchstart’,e=>{e.preventDefault();craftOpen?closeCraft():openCraft();},{passive:false});
}
setupMobile();

